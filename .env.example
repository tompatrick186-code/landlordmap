# =============================================================================
# LandlordMap Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard
# Project Settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Anthropic Claude — https://console.anthropic.com/
# Used for the AI assistant chat widget
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/
# Publishable key is safe to expose; secret key must stay server-only
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_AGENCY_PRICE_ID=price_your-agency-price-id

# -----------------------------------------------------------------------------
# Mapbox — https://account.mapbox.com/
# Used for the interactive property map
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJ5b3VyLXRva2VuIn0.xxx

# -----------------------------------------------------------------------------
# Resend — https://resend.com/
# Used for transactional emails (rent reminders, maintenance alerts)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=hello@yourdomain.com

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
